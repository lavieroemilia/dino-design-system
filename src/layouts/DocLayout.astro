---
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description?: string;
  headings?: MarkdownHeading[];
}

const { title, description, headings = [] } = Astro.props;

const navItems = [
  { label: 'Button',       href: '/components/button' },
  { label: 'Progress Bar', href: '/components/progress-bar' },
  { label: 'Typography',   href: '/components/typography' },
];

const filteredHeadings = headings.filter(h => h.depth <= 3);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Dino Design System</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-family-body);
      font-size: 15px;
      line-height: 1.65;
      background: var(--surface-page);
      color: var(--text-body-default);
      min-height: 100vh;
    }

    /* ── Topbar ── */
    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 56px;
      background: var(--surface-elevate);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 12px;
      z-index: 100;
    }

    .topbar__logo {
      font-family: var(--font-family-headings);
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--primary-default);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .topbar__divider {
      width: 1px;
      height: 18px;
      background: var(--border-default);
      opacity: 0.4;
    }

    .topbar__section {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-placeholder);
    }

    /* ── Shell ── */
    .shell {
      display: grid;
      grid-template-columns: 220px 1fr 200px;
      min-height: 100vh;
      padding-top: 56px;
    }

    @media (max-width: 1024px) {
      .shell { grid-template-columns: 200px 1fr; }
      .toc   { display: none; }
    }
    @media (max-width: 680px) {
      .shell   { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }

    /* ── Sidebar ── */
    .sidebar {
      position: sticky;
      top: 56px;
      height: calc(100vh - 56px);
      overflow-y: auto;
      padding: 28px 0 28px 12px;
      border-right: 1px solid rgba(255,255,255,0.06);
      background: var(--surface-page);
      scrollbar-width: thin;
      scrollbar-color: var(--neutral-700) transparent;
    }

    .sidebar__group-label {
      font-family: var(--font-family-headings);
      font-size: var(--text-h4-default);
      font-weight: 700;
      letter-spacing: 0;
      text-transform: uppercase;
      color: var(--text-placeholder);
      padding: 0 12px;
      margin-bottom: 8px;
    }

    .sidebar__link {
      display: flex;
      align-items: center;
      padding: 7px 12px;
      border-radius: 6px 0 0 6px;
      font-size: var(--text-body-default);
      font-weight: 500;
      color: var(--text-body-default);
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
      position: relative;
    }

    .sidebar__link:hover {
      background: var(--surface-hover-dark);
      color: var(--text-headings);
    }

    .sidebar__link[aria-current="page"] {
      background: var(--primary-900);
      color: var(--primary-300);
      font-weight: 600;
    }

    .sidebar__link[aria-current="page"]::after {
      content: '';
      position: absolute;
      right: 0; top: 4px; bottom: 4px;
      width: 2px;
      background: var(--primary-default);
      border-radius: 2px 0 0 2px;
    }

    /* ── Main ── */
    .main {
      padding: 48px 56px 96px;
      min-width: 0;
    }

    .main__header {
      margin-bottom: 24px;
      padding-bottom: 12px;
    }

    .main__title {
      font-family: var(--font-family-headings);
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--text-headings);
      line-height: 1.15;
      text-transform: uppercase;
    }

    .main__description {
      margin-top: 12px;
      font-size: 1rem;
      color: var(--text-body-default);
      max-width: 62ch;
    }

    /* ── Prose ── */
    .main :global(h2) {
      font-family: var(--font-family-headings);
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-headings);
      margin-top: 64px;
      margin-bottom: 12px;
      scroll-margin-top: 80px;
    }

    .main :global(h3) {
      font-family: var(--font-family-headings);
      font-size: var(--text-h3-default);
      font-weight: 600;
      color: var(--neutral-white-100);
      margin-top: 48px;
      margin-bottom: 0px;
      scroll-margin-top: 80px;
    }

    .main :global(p) {
      color: var(--text-body-default);
      margin-bottom: 24px;
      max-width: 72ch;
    }

    .main :global(code) {
      font-family: 'Courier New', monospace;
      font-size: 0.82em;
      background: var(--surface-elevate);
      color: var(--primary-300);
      padding: 2px 6px;
      border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .main :global(pre) {
      font-family: 'Courier New', monospace;
      font-size: 0.82rem;
      background: var(--surface-elevate);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 20px 24px;
      overflow-x: auto;
      margin: 16px 0 24px;
      color: var(--neutral-200);
      line-height: 1.7;
    }

    .main :global(pre code) {
      background: none;
      border: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    .main :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin: 20px 0 28px;
    }

    .main :global(th) {
      font-family: var(--font-family-headings);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0;
      text-transform: uppercase;
      color: var(--text-placeholder);
      text-align: left;
      padding: 8px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .main :global(td) {
      padding: 10px 14px;
      color: var(--text-body-default);
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: top;
    }

    .main :global(tr:last-child td) { border-bottom: none; }

    .main :global(ul),
    .main :global(ol) {
      padding-left: 20px;
      margin-bottom: 16px;
      color: var(--text-body-default);
    }

    .main :global(li)     { margin-bottom: 6px; }
    .main :global(strong) { color: var(--text-headings); font-weight: 600; }

    .main :global(hr) {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin: 40px 0;
    }

    /* ── TOC ── */
    .toc {
      position: sticky;
      top: 56px;
      height: calc(100vh - 56px);
      overflow-y: auto;
      padding: 28px 16px 28px 20px;
      background: var(--surface-page);
      scrollbar-width: thin;
      scrollbar-color: var(--neutral-700) transparent;
    }

    .toc__label {
      font-family: var(--font-family-headings);
      font-size: var(--text-h4
      -default);
      font-weight: 700;
      letter-spacing: 0;
      text-transform: uppercase;
      color: var(--text-placeholder);
      margin-bottom: 10px;
    }

    .toc__list { list-style: none; padding: 0; }
    .toc__item { margin-bottom: 2px; }

    .toc__link {
      display: block;
      font-size: var(--text-body-default);
      color: var(--text-placeholder);
      text-decoration: none;
      padding: 4px 8px;
      border-radius: 4px;
      transition: color 0.15s, background 0.15s;
      line-height: 1.8;
    }

    .toc__link:hover {
      color: var(--text-headings);
      background: var(--surface-hover-dark);
    }

    .toc__link.is-active {
      color: var(--primary-300);
      background: var(--primary-900);
    }

    .toc__link[data-depth="3"] { padding-left: 18px; }

    /* Headings */
.main :global(h1) { font-size: var(--font-size-h1); line-height: var(--line-height-h1); font-weight: var(--font-weight-bold); }
.main :global(h2) { font-size: var(--font-size-h2); line-height: var(--line-height-h2); font-weight: var(--font-weight-bold); }
.main :global(h3) { font-size: var(--font-size-h3); line-height: var(--line-height-h3); font-weight: var(--font-weight-semibold); }
.main :global(h4) { font-size: var(--font-size-h4); line-height: var(--line-height-h4); font-weight: var(--font-weight-semibold); }
.main :global(h5) { font-size: var(--font-size-h5); line-height: var(--line-height-h5); font-weight: var(--font-weight-medium); }
.main :global(h6) { font-size: var(--font-size-h6); line-height: var(--line-height-h6); font-weight: var(--font-weight-medium); }

/* Paragraphs */
.main :global(p)  { font-size: var(--font-size-paragraph-md); line-height: var(--line-height-paragraph-md); }
  </style>
</head>
<body>

  <header class="topbar" role="banner">
    <a href="/" class="topbar__logo">🦕 Dino</a>
    <div class="topbar__divider" aria-hidden="true"></div>
    <span class="topbar__section">Design System</span>
  </header>

  <div class="shell">

    <nav class="sidebar" aria-label="Componentes">
      <p class="sidebar__group-label">Componentes</p>
      {navItems.map(item => (
        <a
          href={item.href}
          class="sidebar__link"
          aria-current={Astro.url.pathname === item.href ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <main class="main" id="main-content">
      <header class="main__header">
        <h1 class="main__title">{title}</h1>
        {description && <p class="main__description">{description}</p>}
      </header>
      <slot />
    </main>

    <aside class="toc" aria-label="En esta página">
      {filteredHeadings.length > 0 && (
        <>
          <p class="toc__label">En esta página</p>
          <ul class="toc__list">
            {filteredHeadings.map(h => (
              <li class="toc__item">
                <a href={`#${h.slug}`} class="toc__link" data-depth={String(h.depth)}>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </aside>

  </div>

  <script>
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc__link');
    if (tocLinks.length) {
      const headingEls = Array.from(tocLinks)
        .map(l => document.getElementById(l.getAttribute('href')?.slice(1) ?? ''))
        .filter(Boolean) as HTMLElement[];

      const observer = new IntersectionObserver(entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('is-active'));
            document.querySelector(`.toc__link[href="#${entry.target.id}"]`)?.classList.add('is-active');
            break;
          }
        }
      }, { rootMargin: '-56px 0px -60% 0px', threshold: 0 });

      headingEls.forEach(el => observer.observe(el));
    }
  </script>

</body>
</html>
