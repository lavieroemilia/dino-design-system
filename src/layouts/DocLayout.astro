---
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description?: string;
  headings?: MarkdownHeading[];
}

const { title, description, headings = [] } = Astro.props;

const pages = await Astro.glob('../pages/components/*.astro');

const navItems = pages
  .map(page => {
    const slug = page.file.split('/').pop()?.replace('.astro', '') ?? '';
    const label = slug
      .split('-')
      .map((w: string) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(' ');
    return { label, href: `/components/${slug}` };
  })
  .sort((a: { label: string }, b: { label: string }) => a.label.localeCompare(b.label));

const filteredHeadings = headings.filter(h => h.depth <= 3);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Dino Design System</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-family-body);
      font-size: 16px;
      line-height: 1.5;
      background: var(--surface-page);
      color: var(--text-body-default);
      min-height: 100vh;
    }

    /* ── Topbar ── */
    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 56px;
      background: var(--surface-elevate);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      padding: 0 var(--spacing-24);
      gap: var(--spacing-12);
      z-index: 100;
    }

    .topbar__logo {
      font-family: var(--font-family-headings);
      font-weight: 800;
      font-size: var(--font-size-h6);
      color: var(--primary-default);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .topbar__divider {
      width: 1px;
      height: 18px;
      background: var(--border-default);
      opacity: 0.4;
    }

    .topbar__section {
      font-size: var(--font-size-paragraph-cp);
      font-weight: var(--font-weight-medium);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-placeholder);
    }

    /* ── Shell ── */
    .shell {
      display: grid;
      grid-template-columns: 220px 1fr 200px;
      min-height: 100vh;
      padding-top: 56px;
    }

    @media (max-width: 1024px) {
      .shell { grid-template-columns: 200px 1fr; }
      .toc   { display: none; }
    }
    @media (max-width: 680px) {
      .shell   { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }

    /* ── Sidebar ── */
    .sidebar {
      position: sticky;
      top: 56px;
      height: calc(100vh - 56px);
      overflow-y: auto;
      padding: var(--spacing-28) 0 var(--spacing-28) var(--spacing-12);
      border-right: 1px solid rgba(255,255,255,0.06);
      background: var(--surface-page);
      scrollbar-width: thin;
      scrollbar-color: var(--neutral-700) transparent;
    }

    .sidebar__group-label {
      font-family: var(--font-family-headings);
      font-size: var(--font-size-paragraph-sm);
      font-weight: var(--font-weight-semibold);
      letter-spacing: none;
      color: var(--text-placeholder);
      padding: 0 var(--spacing-12);
      margin-bottom: var(--spacing-8);
    }

    .sidebar__link {
      display: flex;
      align-items: center;
      padding: 7px var(--spacing-12);
      border-radius: var(--radius-sm) 0 0 var(--radius-sm);
      font-size: var(--font-size-paragraph-sm);
      font-weight: var(--font-weight-default);
      color: var(--text-body-default);
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
      position: relative;
    }

    .sidebar__link:hover {
      background: var(--surface-hover-dark);
      color: var(--text-headings);
    }

    .sidebar__link[aria-current="page"] {
      background: var(--primary-900);
      color: var(--primary-300);
      font-weight: var(--font-weight-semibold);
    }

    .sidebar__link[aria-current="page"]::after {
      content: '';
      position: absolute;
      right: 0; top: 4px; bottom: 4px;
      width: 2px;
      background: var(--primary-default);
      border-radius: 2px 0 0 2px;
    }

    /* ── Main ── */
    .main {
  padding: var(--spacing-64);
  min-width: 0;
  max-width: 860px;
  margin: 0 auto;
    }

    .main__header {
      margin-bottom: var(--spacing-12);
      padding-bottom: var(--spacing-12);
    }

    .main__title {
      font-family: var(--font-family-headings);
      font-size: var(--font-size-h1);
      font-weight: var(--font-weight-bold);
      letter-spacing: none;
      color: var(--text-headings);
      line-height: var(--line-height-h1);
      margin-bottom: var(--spacing-12);
      text-transform: uppercase;
    }

    .main__description {
      margin-top: var(--spacing-12);
      font-size: var(--font-size-paragraph-lg);
      line-height: var(--line-height-paragraph-lg);
      color: var(--text-body-default);
      padding-bottom: var(--spacing-4);
      max-width: 62ch;
    }

    /* ── Prose ── */
    .main :global(h2) {
      font-family: var(--font-family-headings);
      font-size: var(--font-size-h2);
      font-weight: var(--font-weight-bold);
      color: var(--text-headings);
      margin-top: var(--spacing-64);
      margin-bottom: var(--spacing-12);
      scroll-margin-top: 80px;
    }

    .main :global(h3) {
      font-family: var(--font-family-headings);
      font-size: var(--font-size-h3);
      font-weight: 600;
      color: var(--neutral-white-100);
      margin-top: var(--spacing-40);
      margin-bottom: 0;
      scroll-margin-top: 80px;
    }

    .main :global(p) {
      color: var(--text-body-default);
      margin-bottom: var(--spacing-24);
      max-width: 72ch;
    }

    .main :global(code) {
      font-family: 'Courier New', monospace;
      font-size: var(--font-size-paragraph-cp);
      background: var(--surface-elevate);
      color: var(--primary-300);
      padding: var(--spacing-2) var(--spacing-8);
      border-radius: var(--radius-xsm);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .main :global(pre) {
      font-family: 'Courier New', monospace;
      font-size: var(--font-size-paragraph-cp);
      background: var(--surface-elevate);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--radius-xlg);
      padding: var(--spacing-20) var(--spacing-24);
      overflow-x: auto;
      margin: var(--spacing-16) 0 var(--spacing-48);
      color: var(--neutral-200);
      line-height: 1.7;
    }

    .main :global(pre code) {
      background: none;
      border: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    .main :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--font-size-paragraph-sm);
      margin: var(--spacing-20) 0 var(--spacing-28);
    }

    .main :global(th) {
      font-family: var(--font-family-headings);
      font-size: var(--font-size-paragraph-cp);
      font-weight: var(--font-weight-bold);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-placeholder);
      text-align: left;
      padding: var(--spacing-8) 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .main :global(td) {
      padding: var(--spacing-10) 14px;
      color: var(--text-body-default);
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: top;
    }

    .main :global(tr:last-child td) { border-bottom: none; }

    .main :global(ul),
    .main :global(ol) {
      padding-left: var(--spacing-20);
      margin-bottom: var(--spacing-16);
      color: var(--text-body-default);
    }

    .main :global(li)     { margin-bottom: var(--spacing-4); }
    .main :global(strong) { color: var(--text-headings); font-weight: var(--font-weight-semibold); }

    .main :global(hr) {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin: var(--spacing-40) 0;
    }

    /* ── TOC ── */
    .toc {
      position: sticky;
      top: 56px;
      height: calc(100vh - 56px);
      overflow-y: auto;
      padding: var(--spacing-28) var(--spacing-16) var(--spacing-28) var(--spacing-20);
      background: var(--surface-page);
      scrollbar-width: thin;
      scrollbar-color: var(--neutral-700) transparent;
    }

    .toc__label {
      font-family: var(--font-family-paragraph);
      font-size: var(--font-size-paragraph-sm);
      font-weight: var(--font-weight-bold);
      letter-spacing: none;
      color: var(--text-placeholder);
      margin-bottom: var(--spacing-10);
    }

    .toc__list { list-style: none; padding: 0; }
    .toc__item { margin-bottom: 2px; }

    .toc__link {
      display: block;
      font-size: var(--font-size-paragraph-sm);
      color: var(--text-placeholder);
      text-decoration: none;
      padding: var(--spacing-4) var(--spacing-8);
      border-radius: var(--radius-xsm);
      transition: color 0.15s, background 0.15s;
      line-height: 1.8;
    }

    .toc__link:hover {
      color: var(--text-headings);
      background: var(--surface-hover-dark);
    }

    .toc__link.is-active {
      color: var(--primary-300);
      background: var(--primary-900);
    }

    .toc__link[data-depth="3"] { padding-left: var(--spacing-20); }

    /* Headings */
.main :global(h1) { font-size: var(--font-size-h1); line-height: var(--line-height-h1); font-weight: var(--font-weight-bold); }
.main :global(h2) { font-size: var(--font-size-h2); line-height: var(--line-height-h2); font-weight: var(--font-weight-bold); }
.main :global(h3) { font-size: var(--font-size-h3); line-height: var(--line-height-h3); font-weight: var(--font-weight-semibold); }
.main :global(h4) { font-size: var(--font-size-h4); line-height: var(--line-height-h4); font-weight: var(--font-weight-semibold); }
.main :global(h5) { font-size: var(--font-size-h5); line-height: var(--line-height-h5); font-weight: var(--font-weight-medium); }
.main :global(h6) { font-size: var(--font-size-h6); line-height: var(--line-height-h6); font-weight: var(--font-weight-medium); }

/* Paragraphs */
.main :global(p)  { font-size: var(--font-size-paragraph-md); line-height: var(--line-height-paragraph-md); }
  </style>
</head>
<body>

  <header class="topbar" role="banner">
    <a href="/overview" class="topbar__logo">🦕 Dino</a>
    <div class="topbar__divider" aria-hidden="true"></div>
    <span class="topbar__section">Design System</span>
  </header>

  <div class="shell">

    <nav class="sidebar" aria-label="Components">
      <p class="sidebar__group-label">Components</p>
      {navItems.map(item => (
        <a
          href={item.href}
          class="sidebar__link"
          aria-current={Astro.url.pathname === item.href ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <main class="main" id="main-content">
      <header class="main__header">
        <h1 class="main__title">{title}</h1>
        {description && <p class="main__description">{description}</p>}
      </header>
      <slot />
    </main>

    <aside class="toc" aria-label="On this page">
      {filteredHeadings.length > 0 && (
        <>
          <p class="toc__label">On this page</p>
          <ul class="toc__list">
            {filteredHeadings.map(h => (
              <li class="toc__item">
                <a href={`#${h.slug}`} class="toc__link" data-depth={String(h.depth)}>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </aside>

  </div>

  <script>
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc__link');
    if (tocLinks.length) {
      const headingEls = Array.from(tocLinks)
        .map(l => document.getElementById(l.getAttribute('href')?.slice(1) ?? ''))
        .filter(Boolean) as HTMLElement[];

      const observer = new IntersectionObserver(entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('is-active'));
            document.querySelector(`.toc__link[href="#${entry.target.id}"]`)?.classList.add('is-active');
            break;
          }
        }
      }, { rootMargin: '-56px 0px -60% 0px', threshold: 0 });

      headingEls.forEach(el => observer.observe(el));
    }
  </script>

</body>
</html>
