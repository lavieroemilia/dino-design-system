## 📦 Boilerplate script (button toggles + optional range)

```astro
<script>
  const stage        = document.getElementById('preview-stage');
  const valueDisplay = document.getElementById('value-display');       // only if range exists
  const rangeEl      = document.getElementById('ctrl-value') as HTMLInputElement | null; // only if range exists

  const state: Record<string, string> = { propA: 'default', propB: 'false' };

  function render() {
    const card = stage?.querySelector('.component-class') as HTMLElement | null;
    if (!card) return;
    // mutate card DOM based on state
  }

  document.querySelectorAll<HTMLButtonElement>('.ctrl-btn[data-prop]').forEach(btn => {
    btn.addEventListener('click', () => {
      const prop = btn.dataset.prop!;
      document.querySelectorAll<HTMLButtonElement>(`.ctrl-btn[data-prop="${prop}"]`)
        .forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      state[prop] = btn.dataset.value!;
      render();
    });
  });

  // include only when a range input exists:
  rangeEl?.addEventListener('input', () => {
    state.value = rangeEl.value;
    render();
  });
</script>
```

