---
interface Props {
  /** The visible label text */
  label?: string;
  /** Shows the red asterisk — use for required fields */
  required?: boolean;
  /** Short hint text. When provided, shows the question-mark icon as a tooltip trigger */
  hint?: string;
  /** id of the input this label belongs to — wires up the click area */
  for?: string;
  /** Optional id for playground scripting */
  id?: string;
}

const {
  label    = 'Label',
  required = false,
  hint,
  for: htmlFor,
  id,
} = Astro.props;
---

<label
  class:list={['label', { 'label--required': required }]}
  for={htmlFor}
  id={id}
>
  {required && (
    <span class="label__asterisk" aria-hidden="true">*</span>
  )}
  <span class="label__text">{label}</span>
  {hint && (
    <button
      class="label__hint-btn"
      type="button"
      title={hint}
      aria-label={`Más info: ${hint}`}
    >
      <!-- heroicons-outline/question-mark-circle -->
      <svg
        class="label__hint-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
      </svg>
    </button>
  )}
</label>

<style>
  /* ── Container ──────────────────────────────────────────────── */
  .label {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-4);
    cursor: default;
    line-height: 0; /* prevents extra space from inline-flex baseline */
  }

  /* ── Label text ─────────────────────────────────────────────── */
  .label__text {
    font-family: var(--font-family-body);
    font-size: var(--font-size-paragraph-md);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-paragraph-md);
    color: var(--text-body-default);
  }

  /* ── Required asterisk ──────────────────────────────────────── */
  .label__asterisk {
    font-family: var(--font-family-body);
    font-size: var(--font-size-paragraph-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-paragraph-md);
    color: var(--icon-error);
    user-select: none;
  }

  /* ── Hint button + icon ─────────────────────────────────────── */
  .label__hint-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--text-placeholder);
    line-height: 0;
    border-radius: var(--radius-xsm);
    transition: color 0.15s;
  }

  .label__hint-btn:hover {
    color: var(--text-body-default);
  }

  .label__hint-btn:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 2px;
  }

  .label__hint-icon {
    display: block;
    flex-shrink: 0;
  }
</style>
