<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dino Design System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>

  <main class="landing">
    <img class="landing__logo" src="/logo.svg" alt="Dino Design System" />

    <h1>Built to scale.<br />Designed for play.</h1>

    <p>The shared language for designers, developers, and anyone who builds Dino.</p>

    <div class="landing__cta">
      <a href="/overview" class="btn btn--primary btn--lg">Get started</a>
      <a href="/components/button" class="btn btn--tertiary btn--lg">View components</a>
    </div>
  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font-family-body);
    background: var(--surface-page);
    color: var(--text-body-default);
  }

  .landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: var(--spacing-24);
    text-align: center;
  }

  .landing__logo {
    width: 160px;
    margin-bottom: var(--spacing-32);
  }

  h1 {
    font-family: var(--font-family-headings);
    font-size: clamp(40px, 8vw, 80px);
    line-height: 1.1;
    font-weight: var(--font-weight-bold);
    color: var(--text-headings);
    text-align: center;
    margin-bottom: var(--spacing-24);
    letter-spacing: -0.02em;
  }

  p {
    font-size: var(--font-size-paragraph-lg);
    color: var(--text-body-default);
    text-align: center;
    max-width: 480px;
    line-height: 1.6;
    margin-bottom: var(--spacing-40);
  }

  .landing__cta {
    display: flex;
    gap: var(--spacing-12);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Button styles (copied from Button.astro) ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    position: relative;
    transition: background 0.15s, transform 0.1s;
    white-space: nowrap;
    box-shadow: var(--shadow-button);
  }

  .btn--lg { height: 48px; padding: 10px 16px; font-size: var(--font-size-paragraph-md); line-height: var(--line-height-paragraph-md); }

  .btn--primary {
    background: var(--surface-button-primary-default);
    color: var(--text-action-light);
    text-shadow: var(--shadow-text);
  }
  .btn--primary:hover {
    background: var(--surface-button-primary-hover);
  }

  .btn--tertiary {
    background: var(--surface-button-transparent-default);
    color: var(--text-action-light);
    text-shadow: var(--shadow-text);
  }
  .btn--tertiary:hover {
    background: var(--surface-button-transparent-hover);
  }

  .btn:active {
    transform: translateY(1px);
    box-shadow: var(--shadow-button-active);
  }
</style>
