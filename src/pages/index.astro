  <hr class="overview-divider" />

  <!-- ── Tipografía ── -->
  <section class="overview-section" id="tipografia">
    <h2>Tipografía</h2>
    <p>
      Rubik es la única familia del sistema. Su geometría redondeada equilibra la energía
      de los colores saturados con legibilidad en pantallas pequeñas.
    </p>

    <div class="type-table">
      <div class="type-row type-row--header">
        <span>Token</span><span>Size · Line-height</span><span>Peso</span><span>Muestra</span>
      </div>
      <div class="type-row">
        <code>h1</code><span>48px · 56px <em>(desktop)</em></span><span>700</span>
        <span class="type-sample" style="font-size:28px; font-weight:700; line-height:1.2;">Estudia mejor</span>
      </div>
      <div class="type-row">
        <code>h2</code><span>40px · 48px</span><span>700</span>
        <span class="type-sample" style="font-size:22px; font-weight:700;">Progreso del día</span>
      </div>
      <div class="type-row">
        <code>h3</code><span>32px · 40px</span><span>600</span>
        <span class="type-sample" style="font-size:18px; font-weight:600;">Preguntas de Física</span>
      </div>
      <div class="type-row">
        <code>paragraph-lg</code><span>18px · 20px</span><span>400</span>
        <span class="type-sample" style="font-size:16px; font-weight:400;">Selecciona la respuesta correcta</span>
      </div>
      <div class="type-row">
        <code>paragraph-md</code><span>16px · 20px</span><span>400</span>
        <span class="type-sample" style="font-size:14px; font-weight:400;">La mitocondria es la central eléctrica de la célula</span>
      </div>
      <div class="type-row">
        <code>paragraph-sm</code><span>14px · 18px</span><span>400</span>
        <span class="type-sample" style="font-size:13px; font-weight:400;">Retroalimentación de respuesta</span>
      </div>
      <div class="type-row">
        <code>paragraph-cp</code><span>11px · 16px</span><span>500</span>
        <span class="type-sample" style="font-size:11px; font-weight:500; letter-spacing:0.06em; text-transform:uppercase;">Caption · Label</span>
      </div>
    </div>
  </section>

  <hr class="overview-divider" />

  <!-- ── Componentes ── -->
  <section class="overview-section" id="componentes">
    <h2>Componentes</h2>
    <p>
      Cada componente vive en un archivo <code>.astro</code>, consume exclusivamente tokens
      semánticos y documenta sus props, variantes y estados.
    </p>

    <div class="component-grid">

      <a href="/components/button" class="component-card">
        <div class="component-card__preview">
          <Button variant="primary" size="md" label="Continuar" />
          <Button variant="ghost" size="md" label="Omitir" />
        </div>
        <div class="component-card__info">
          <strong>Button</strong>
          <span>6 variantes · 4 tamaños · estados disabled</span>
          <div class="component-card__tags">
            <span class="tag">primary</span>
            <span class="tag">secondary</span>
            <span class="tag">danger</span>
            <span class="tag">premium</span>
          </div>
        </div>
      </a>

      <a href="/components/progress-bar" class="component-card">
        <div class="component-card__preview component-card__preview--col">
          <ProgressBar value={72} color="yellow" size="md" />
          <ProgressBar value={45} color="green" size="sm" />
        </div>
        <div class="component-card__info">
          <strong>Progress Bar</strong>
          <span>5 colores · 4 tamaños · gradientes</span>
          <div class="component-card__tags">
            <span class="tag">yellow</span>
            <span class="tag">green</span>
            <span class="tag">purple</span>
          </div>
        </div>
      </a>

      <a href="/components/option-card" class="component-card">
        <div class="component-card__preview component-card__preview--col">
          <OptionCard label="Opción A" status="default" />
          <OptionCard label="Opción B" selected={true} />
        </div>
        <div class="component-card__info">
          <strong>Option Card</strong>
          <span>5 estados · badge · accesible con radio input</span>
          <div class="component-card__tags">
            <span class="tag">default</span>
            <span class="tag">selected</span>
            <span class="tag">error</span>
          </div>
        </div>
      </a>

    </div>
  </section>

  <hr class="overview-divider" />

  <!-- ── Footer ── -->
  <section class="overview-footer">
    <p>
      Diseñado por <a href="https://www.emilialaviero.com" target="_blank" rel="noopener">Emilia Laviero</a>
      · Product Designer @ Ucademy · 2025
    </p>
  </section>

</DocLayout>

<style>

  /* ── Hero ── */
  .overview-hero {
    padding-bottom: var(--spacing-8);
  }

  .overview-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-20);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 3px var(--spacing-10);
    border-radius: var(--radius-round);
