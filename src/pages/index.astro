            <span>Blue</span>
          </div>
          <div class="color-scale">
            <div class="color-scale__step" style="background:#edfdff;" title="#edfdff"><span>50</span></div>
            <div class="color-scale__step" style="background:#dbf9ff;" title="#dbf9ff"><span>100</span></div>
