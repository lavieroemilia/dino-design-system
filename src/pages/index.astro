          <span style="color:#171621;">White</span>
          <code style="color:#171621;">#ffffff</code>
        </div>
        <div class="foundation-swatch foundation-swatch--alphas" style="background: linear-gradient(90deg, #ffffff1a, #ffffff66, #ffffffcc, #ffffff);">
          <span>White 10–100</span>
        </div>
        <div class="foundation-swatch" style="background:#0d0c12;">
          <span>Black</span>
          <code>#0d0c12</code>
        </div>
        <div class="foundation-swatch foundation-swatch--alphas" style="background: linear-gradient(90deg, #0d0c121a, #0d0c1266, #0d0c12cc, #0d0c12);">
