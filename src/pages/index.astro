          <div class="color-scale">
            <div class="color-scale__step" style="background:#fff4ee;" title="#fff4ee"><span>50</span></div>
            <div class="color-scale__step" style="background:#ffe8dc;" title="#ffe8dc"><span>100</span></div>
            <div class="color-scale__step" style="background:#ffd0b9;" title="#ffd0b9"><span>200</span></div>
            <div class="color-scale__step" style="background:#ffb895;" title="#ffb895"><span>300</span></div>
            <div class="color-scale__step" style="background:#ffa172;" title="#ffa172"><span>400</span></div>
            <div class="color-scale__step color-scale__step--default" style="background:#ff8a4f;" title="#ff8a4f"><span>def</span></div>
