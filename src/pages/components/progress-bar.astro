---
import DocLayout from '../../layouts/DocLayout.astro';
import ProgressBar from '../../components/ProgressBar.astro';

const headings = [
  { depth: 2, slug: 'variants',     text: 'Variants' },
  { depth: 3, slug: 'size',         text: 'Size' },
  { depth: 3, slug: 'color',        text: 'Color' },
  { depth: 3, slug: 'label',        text: 'Label' },
  { depth: 3, slug: 'icon',         text: 'Icon' },
  { depth: 3, slug: 'fill-states',  text: 'Fill states' },
  { depth: 2, slug: 'usage',        text: 'Usage' },
  { depth: 2, slug: 'combinations', text: 'Combinations' },
  { depth: 2, slug: 'dos-donts',    text: "Do's & Don'ts" },
];
---

<DocLayout
  title="Progress Bar"
  description="Shows students how far they've come and how far they have left to go. Works for lesson progress, fossil collection, or any goal with a measurable end."
  headings={headings}
>

  <!-- PLAYGROUND -->
  <section class="playground" aria-label="Interactive preview">

    <div class="playground__stage" id="preview-stage">
      <div class="preview-wrap">
        <ProgressBar value={50} size="lg" color="yellow" />
      </div>
    </div>

    <div class="playground__controls" role="group" aria-label="Playground controls">

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Color</legend>
        <div class="ctrl-group__options">
          {['yellow','green','red','orange','purple'].map(c => (
            <button
              class:list={['ctrl-btn', { 'is-active': c === 'yellow' }]}
              data-prop="color"
              data-value={c}
            >{c}</button>
          ))}
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Size</legend>
        <div class="ctrl-group__options">
          {['xs','sm','md','lg'].map(s => (
            <button
              class:list={['ctrl-btn', { 'is-active': s === 'lg' }]}
              data-prop="size"
              data-value={s}
            >{s}</button>
          ))}
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Label</legend>
        <div class="ctrl-group__options">
          <button class="ctrl-btn is-active" data-prop="count" data-value="">None</button>
          <button class="ctrl-btn"           data-prop="count" data-value="50 / 300">Count</button>
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Icon</legend>
        <div class="ctrl-group__options">
          <button class="ctrl-btn is-active" data-prop="icon" data-value="false">None</button>
          <button class="ctrl-btn"           data-prop="icon" data-value="true">Fossil</button>
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Value — <span id="value-display">50</span>%</legend>
        <input type="range" id="ctrl-value" min="0" max="100" value="50" class="ctrl-range" aria-label="Progress value" />
      </fieldset>

    </div>

  </section>


  <!-- VARIANTS -->
  <h2 id="variants">Variants</h2>

  <h3 id="size">Size</h3>
  <p>Use <code>lg</code> at the top of lesson screens. Drop to <code>sm</code> or <code>xs</code> when the bar is a secondary indicator in a card or tight layout.</p>
  <div class="example-row example-row--col">
    {[
      { size: 'lg', label: 'lg — 24px' },
      { size: 'md', label: 'md — 20px' },
      { size: 'sm', label: 'sm — 12px' },
      { size: 'xs', label: 'xs — 6px'  },
    ].map(({ size, label }) => (
      <div class="size-row">
        <span class="size-label">{label}</span>
        <ProgressBar value={60} size={size as any} color="yellow" />
      </div>
    ))}
  </div>

  <h3 id="color">Color</h3>
  <p>Assign one color per subject and keep it consistent. Students will start associating the color with the subject before they even read the label.</p>
  <div class="example-row example-row--col">
    {[
      { color: 'yellow', label: 'yellow' },
      { color: 'green',  label: 'green'  },
      { color: 'red',    label: 'red'    },
      { color: 'orange', label: 'orange' },
      { color: 'purple', label: 'purple' },
    ].map(({ color, label }) => (
      <div class="size-row">
        <span class="size-label">{label}</span>
        <ProgressBar value={65} size="lg" color={color as any} />
      </div>
    ))}
  </div>

  <h3 id="label">Label</h3>
  <p>
    Overlay the student's fossil count directly on the bar. Pass a string like <code>"120 / 300"</code> to show how many they have and how many they need. Only works on <code>lg</code> and <code>md</code>.
  </p>
  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">lg · count</span>
      <ProgressBar value={55} size="lg" color="yellow" count="50 / 300" />
    </div>
    <div class="size-row">
      <span class="size-label">md · count</span>
      <ProgressBar value={55} size="md" color="yellow" count="50 / 300" />
    </div>
    <div class="size-row">
      <span class="size-label">sm · count (ignored)</span>
      <ProgressBar value={55} size="sm" color="yellow" count="50 / 300" />
    </div>
  </div>

  <h3 id="icon">Icon</h3>
  <p>
    Add the fossil icon to make the count feel more like a reward than a metric. Use the icon alone, the count alone, or both together. Only shows on <code>lg</code> and <code>md</code>.
  </p>
  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">icon only</span>
      <ProgressBar value={55} size="lg" color="yellow" showIcon={true} />
    </div>
    <div class="size-row">
      <span class="size-label">count only</span>
      <ProgressBar value={55} size="lg" color="yellow" count="50 / 300" />
    </div>
    <div class="size-row">
      <span class="size-label">count + icon</span>
      <ProgressBar value={55} size="lg" color="yellow" count="50 / 300" showIcon={true} />
    </div>
    <div class="size-row">
      <span class="size-label">md · count + icon</span>
      <ProgressBar value={55} size="md" color="green" count="120 / 300" showIcon={true} />
    </div>
  </div>

  <h3 id="fill-states">Fill states</h3>
  <p>From empty to complete. At 100%, make sure the surrounding UI celebrates. The bar alone isn't enough.</p>
  <div class="example-row example-row--col">
    {[0, 25, 50, 75, 100].map(v => (
      <div class="size-row">
        <span class="size-label">{v}%</span>
        <ProgressBar value={v} size="lg" color="yellow" />
      </div>
    ))}
  </div>


  <!-- USAGE -->
  <h2 id="usage">Usage</h2>
  <p>Put it at the top of every lesson screen and assign one color per subject. Students recognize their subjects by color before they read the label, so pick once and keep it consistent.</p>
  <p>Use <code>count</code> and <code>showIcon</code> when the screen is about fossil progress. They're optional and independent: use one, both, or neither depending on the context.</p>


  <!-- COMBINATIONS -->
  <h2 id="combinations">Combinations</h2>
  <p>Put it above the question, not mid-paragraph. Add a count or subject label so students always know what they're tracking.</p>
  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">Biology</span>
      <ProgressBar value={40} size="lg" color="yellow" count="120 / 300" showIcon={true} />
    </div>
    <div class="size-row">
      <span class="size-label">History</span>
      <ProgressBar value={65} size="lg" color="purple" count="195 / 300" showIcon={true} />
    </div>
    <div class="size-row">
      <span class="size-label">Maths</span>
      <ProgressBar value={80} size="lg" color="green" count="240 / 300" showIcon={true} />
    </div>
    <div class="size-row">
      <span class="size-label">Secondary (no label)</span>
      <ProgressBar value={50} size="sm" color="orange" />
    </div>
  </div>


  <!-- DO'S & DON'TS -->
  <h2 id="dos-donts">Do's & Don'ts</h2>

  <div class="dos-donts">
    <div class="dos-donts__col dos-donts__col--do">
      <p class="dos-donts__label">Do</p>
      <ul>
        <li><strong>Pick one color per subject and stick to it.</strong> Consistency is what makes the color useful.</li>
        <li><strong>Use <code>count</code> + <code>showIcon</code> together.</strong> The fossil icon gives context to the number at a glance.</li>
        <li><strong>Use <code>lg</code> as the default.</strong> Smaller sizes only when the bar is a secondary indicator.</li>
      </ul>
    </div>
    <div class="dos-donts__col dos-donts__col--dont">
      <p class="dos-donts__label">Don't</p>
      <ul>
        <li><strong>Don't use <code>count</code> on <code>sm</code> or <code>xs</code>.</strong> The text won't fit and will be silently ignored.</li>
        <li><strong>Don't change a subject's color mid-session.</strong> It breaks the visual pattern students rely on.</li>
        <li><strong>Don't animate to 100% silently.</strong> Reaching the end deserves a celebration state in the parent screen.</li>
      </ul>
    </div>
  </div>

  <hr />

  <p>
    <strong>Related:</strong>
    <a href="/components/button">Button</a> (the primary action that advances the lesson after the bar fills)
    ·
    <a href="/components/option-card">Option Card</a> (the answer the student picks before progress moves forward)
  </p>

</DocLayout>


<style>
  .playground {
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 48px;
  }

  .playground__stage {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    padding: 40px 32px;
    background: var(--surface-page);
  }

  .preview-wrap { width: 360px; }

  .playground__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .ctrl-group { border: none; padding: 0; }

  .ctrl-group__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-placeholder);
    margin-bottom: 8px;
  }

  .ctrl-group__options { display: flex; gap: 6px; flex-wrap: wrap; }

  .ctrl-btn {
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: var(--text-body-default);
    font-family: var(--font-family-body);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .ctrl-btn:hover     { background: var(--surface-hover-dark); }
  .ctrl-btn.is-active {
    background: var(--primary-900);
    color: var(--primary-300);
    border-color: var(--primary-700);
  }

  .ctrl-range {
    width: 100%;
    accent-color: var(--primary-default);
    margin-top: 4px;
  }

  .example-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 24px;
    background: var(--surface-elevate);
    border-radius: 10px;
    margin: 12px 0 8px;
  }

  .example-row--col { flex-direction: column; align-items: stretch; gap: 16px; }

  .size-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    align-items: center;
    gap: 16px;
  }

  .size-label {
    font-size: var(--font-size-paragraph-sm);
    color: var(--text-placeholder);
    white-space: nowrap;
  }

  .dos-donts {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 16px 0 24px;
  }

  .dos-donts__col {
    padding: 16px 20px;
    border-radius: 10px;
  }

  .dos-donts__col--do {
    background: color-mix(in srgb, var(--success-default) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--success-default) 30%, transparent);
  }

  .dos-donts__col--dont {
    background: color-mix(in srgb, var(--error-default) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--error-default) 30%, transparent);
  }

  .dos-donts__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .dos-donts__col--do   .dos-donts__label { color: var(--success-default); }
  .dos-donts__col--dont .dos-donts__label { color: var(--error-default); }
</style>


<script>
  const stage        = document.getElementById('preview-stage');
  const valueDisplay = document.getElementById('value-display');
  const rangeEl      = document.getElementById('ctrl-value');

  const state = { color: 'yellow', size: 'lg', value: '50', count: '', icon: 'false' };

  function render() {
    if (valueDisplay) valueDisplay.textContent = state.value;

    const bar  = stage?.querySelector('.progress');
    const fill = bar?.querySelector('.progress__fill');
    if (!bar || !fill) return;

    // Update bar classes
    bar.className = ['progress', `progress--${state.size}`, `progress--${state.color}`].join(' ');
    bar.setAttribute('aria-valuenow', state.value);
    fill.style.width = `${state.value}%`;

    // Update label overlay
    let labelEl = bar.querySelector('.progress__label');
    const hasLabel = (state.count || state.icon === 'true') && (state.size === 'lg' || state.size === 'md');

    if (hasLabel) {
      if (!labelEl) {
        labelEl = document.createElement('div');
        labelEl.className = 'progress__label';
        bar.appendChild(labelEl);
      }
      // Count text
      let countEl = labelEl.querySelector('.progress__count');
      if (state.count) {
        if (!countEl) {
          countEl = document.createElement('span');
          countEl.className = 'progress__count';
          labelEl.insertBefore(countEl, labelEl.firstChild);
        }
        countEl.textContent = state.count;
      } else {
        countEl?.remove();
      }
      // Icon
      let iconEl = labelEl.querySelector('.progress__icon');
      if (state.icon === 'true') {
        if (!iconEl) {
          iconEl = document.createElement('img');
          iconEl.className = 'progress__icon';
          iconEl.src = '/fossil.svg';
          iconEl.alt = 'fossil';
          iconEl.setAttribute('aria-hidden', 'true');
          labelEl.appendChild(iconEl);
        }
      } else {
        iconEl?.remove();
      }
    } else {
      labelEl?.remove();
    }
  }

  document.querySelectorAll('.ctrl-btn[data-prop]').forEach(btn => {
    btn.addEventListener('click', () => {
      const prop = btn.dataset.prop;
      document.querySelectorAll(`.ctrl-btn[data-prop="${prop}"]`)
        .forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      state[prop] = btn.dataset.value;
      render();
    });
  });

  if (rangeEl) {
    rangeEl.addEventListener('input', () => {
      state.value = rangeEl.value;
      render();
    });
  }
</script>
