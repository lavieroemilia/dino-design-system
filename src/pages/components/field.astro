---
import DocLayout from '../../layouts/DocLayout.astro';
import Field from '../../components/Field/Field.astro';
import Label from '../../components/Label/Label.astro';

const headings = [
  { depth: 2, slug: 'variants',     text: 'Variants' },
  { depth: 3, slug: 'size',         text: 'Size' },
  { depth: 3, slug: 'status',       text: 'Status' },
  { depth: 3, slug: 'result',       text: 'Result' },
  { depth: 3, slug: 'icons',        text: 'Icons' },
  { depth: 2, slug: 'usage',        text: 'Usage' },
  { depth: 2, slug: 'combinations', text: 'Combinations' },
  { depth: 2, slug: 'dos-donts',    text: "Do's & Don'ts" },
];
---

<DocLayout
  title="Field"
  description="The text input students type into. Carries every state from resting to error, so every form feels alive."
  headings={headings}
>

  <!-- ═══════════════════════════════════════════════
       PLAYGROUND
  ════════════════════════════════════════════════ -->
  <section class="playground" aria-label="Interactive preview">

    <div class="playground__stage">
      <div class="preview-wrap">
        <div class="field field--large" id="preview-field">
          <span class="field__icon" id="preview-icon-left" aria-hidden="true" style="display: none;">
            <svg viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M18 10A8 8 0 1 1 2 10a8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a1 1 0 0 0 0 2v3a1 1 0 0 0 1 1h1a1 1 0 1 0 0-2v-3a1 1 0 0 0-1-1H9Z" />
            </svg>
          </span>
          <input class="field__input" type="text" id="preview-input" placeholder="Your nickname" />
          <span class="field__icon" id="preview-icon-right" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="currentColor">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M8 16C12.4183 16 16 12.4183 16 8C16 3.58172 12.4183 0 8 0C3.58172 0 0 3.58172 0 8C0 12.4183 3.58172 16 8 16ZM6.28033 5.21967C5.98744 4.92678 5.51256 4.92678 5.21967 5.21967C4.92678 5.51256 4.92678 5.98744 5.21967 6.28033L6.93934 8L5.21967 9.71967C4.92678 10.0126 4.92678 10.4874 5.21967 10.7803C5.51256 11.0732 5.98744 11.0732 6.28033 10.7803L8 9.06066L9.71967 10.7803C10.0126 11.0732 10.4874 11.0732 10.7803 10.7803C11.0732 10.4874 11.0732 10.0126 10.7803 9.71967L9.06066 8L10.7803 6.28033C11.0732 5.98744 11.0732 5.51256 10.7803 5.21967C10.4874 4.92678 10.0126 4.92678 9.71967 5.21967L8 6.93934L6.28033 5.21967Z" />
            </svg>
          </span>
        </div>
      </div>
    </div>

    <div class="playground__controls" role="group" aria-label="Playground controls">

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Size</legend>
        <div class="ctrl-group__options">
          {['large', 'medium'].map(s => (
            <button
              class:list={['ctrl-btn', { 'is-active': s === 'large' }]}
              data-prop="size"
              data-value={s}
            >{s}</button>
          ))}
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Status</legend>
        <div class="ctrl-group__options">
          {['default', 'hover', 'focus', 'disabled'].map(s => (
            <button
              class:list={['ctrl-btn', { 'is-active': s === 'default' }]}
              data-prop="status"
              data-value={s}
            >{s}</button>
          ))}
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Result</legend>
        <div class="ctrl-group__options">
          {['none', 'error', 'success'].map(r => (
            <button
              class:list={['ctrl-btn', { 'is-active': r === 'none' }]}
              data-prop="result"
              data-value={r}
            >{r}</button>
          ))}
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Icon left</legend>
        <div class="ctrl-group__options">
          <button class="ctrl-btn"           data-prop="iconLeft" data-value="true">true</button>
          <button class="ctrl-btn is-active" data-prop="iconLeft" data-value="false">false</button>
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Icon right</legend>
        <div class="ctrl-group__options">
          <button class="ctrl-btn is-active" data-prop="iconRight" data-value="true">true</button>
          <button class="ctrl-btn"           data-prop="iconRight" data-value="false">false</button>
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Placeholder</legend>
        <input class="ctrl-input" type="text" id="ctrl-placeholder" value="Your nickname" maxlength="40" />
      </fieldset>

    </div>

  </section>


  <!-- ═══════════════════════════════════════════════
       VARIANTS
  ════════════════════════════════════════════════ -->
  <h2 id="variants">Variants</h2>

  <h3 id="size">Size</h3>
  <p>Large is the default for full-width forms like sign-up or profile screens. Medium fits tighter spaces, like a search bar above a lesson list.</p>

  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">Large</span>
      <Field size="large" placeholder="Your nickname" />
    </div>
    <div class="size-row">
      <span class="size-label">Medium</span>
      <Field size="medium" placeholder="Search lessons" />
    </div>
  </div>

  <h3 id="status">Status</h3>
  <p>Default sits quietly until a student interacts. Hover and focus brighten the field so it's clear where typing will land. Disabled locks it down completely.</p>

  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">Default</span>
      <Field status="default" placeholder="Enter your answer" />
    </div>
    <div class="size-row">
      <span class="size-label">Hover</span>
      <Field status="hover" placeholder="Enter your answer" />
    </div>
    <div class="size-row">
      <span class="size-label">Focus</span>
      <Field status="focus" placeholder="Enter your answer" />
    </div>
    <div class="size-row">
      <span class="size-label">Disabled</span>
      <Field status="disabled" placeholder="Locked until lesson 4" />
    </div>
  </div>

  <h3 id="result">Result</h3>
  <p>Use <code>result</code> to confirm or reject what the student typed. Pair error with a short message explaining what to fix.</p>

  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">None</span>
      <Field result="none" placeholder="Class code" />
    </div>
    <div class="size-row">
      <span class="size-label">Error</span>
      <Field result="error" placeholder="Class code" />
    </div>
    <div class="size-row">
      <span class="size-label">Success</span>
      <Field result="success" value="Streak Squad" />
    </div>
  </div>

  <h3 id="icons">Icons</h3>
  <p>The right icon shows the field's result on its own: a circle by default, a warning triangle on error, a check on success. Turn on the left icon when the field needs extra context, like a hint about formatting.</p>

  <div class="example-row example-row--col">
    <div class="size-row">
      <span class="size-label">Default</span>
      <Field placeholder="Search lessons" />
    </div>
    <div class="size-row">
      <span class="size-label">Both icons</span>
      <Field placeholder="Search lessons" iconLeft={true} iconRight={true} />
    </div>
    <div class="size-row">
      <span class="size-label">Left only</span>
      <Field placeholder="Search lessons" iconLeft={true} iconRight={false} />
    </div>
    <div class="size-row">
      <span class="size-label">No icons</span>
      <Field placeholder="Your nickname" iconLeft={false} iconRight={false} />
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════
       USAGE
  ════════════════════════════════════════════════ -->
  <h2 id="usage">Usage</h2>
  <p>Use Field for anything a student types: their name, a class code, an open-ended answer. Pair it with a <strong>Label</strong> above so it's always clear what goes in the box.</p>
  <p>Switch to <code>result="error"</code> only after the student tries to submit, and switch back to <code>none</code> as soon as they start fixing it. Don't leave a field stuck in error once it's valid again.</p>


  <!-- ═══════════════════════════════════════════════
       COMBINATIONS
  ════════════════════════════════════════════════ -->
  <h2 id="combinations">Combinations</h2>
  <p>Stack a <strong>Label</strong> above every Field, especially when <code>required</code>. Follow a form with a primary <strong>Button</strong> ("Join class", "Save changes") and keep it disabled until every required field is filled.</p>

  <div class="example-row example-row--col">
    <div class="form-stack">
      <Label label="Class code" required={true} for="demo-class-code" />
      <Field id="demo-class-code" placeholder="e.g. DINO-204" />
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════
       DO'S & DON'TS
  ════════════════════════════════════════════════ -->
  <h2 id="dos-donts">Do's & Don'ts</h2>

  <div class="dos-donts">
    <div class="dos-donts__col dos-donts__col--do">
      <p class="dos-donts__label">Do</p>
      <ul>
        <li><strong>Pair every Field with a Label.</strong> Students need to know what they're filling in before they tap.</li>
        <li><strong>Clear the error as soon as it's fixed.</strong> Switch back to <code>result="none"</code> the moment the input becomes valid.</li>
        <li><strong>Keep placeholders short and concrete.</strong> "e.g. DINO-204" tells students more than "Enter code".</li>
      </ul>
    </div>
    <div class="dos-donts__col dos-donts__col--dont">
      <p class="dos-donts__label">Don't</p>
      <ul>
        <li><strong>Don't combine error and success.</strong> A field carries one result at a time, never both.</li>
        <li><strong>Don't use disabled to mean "optional."</strong> Disabled means the student can't interact with it at all, not just that it's not required.</li>
        <li><strong>Don't rely on color alone for errors.</strong> Add a short message so the issue is clear without it.</li>
      </ul>
    </div>
  </div>

  <hr />

  <p>
    <strong>Related:</strong>
    <a href="/components/label">Label</a> (sits above every Field to say what goes in it)
    ·
    <a href="/components/button">Button</a> (the action that submits the form)
  </p>

</DocLayout>


<script>
  const preview = document.querySelector<HTMLElement>('#preview-field');
  if (!preview) throw new Error('#preview-field not found');

  const input = document.querySelector<HTMLInputElement>('#preview-input');
  const iconLeft = document.querySelector<HTMLElement>('#preview-icon-left');
  const iconRight = document.querySelector<HTMLElement>('#preview-icon-right');

  function activate(btn: HTMLButtonElement) {
    btn.closest('.ctrl-group__options')!
      .querySelectorAll('.ctrl-btn')
      .forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
  }

  // The right icon reflects the field's result.
  const ICON_RIGHT: Record<string, string> = {
    none: `<svg viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M8 16C12.4183 16 16 12.4183 16 8C16 3.58172 12.4183 0 8 0C3.58172 0 0 3.58172 0 8C0 12.4183 3.58172 16 8 16ZM6.28033 5.21967C5.98744 4.92678 5.51256 4.92678 5.21967 5.21967C4.92678 5.51256 4.92678 5.98744 5.21967 6.28033L6.93934 8L5.21967 9.71967C4.92678 10.0126 4.92678 10.4874 5.21967 10.7803C5.51256 11.0732 5.98744 11.0732 6.28033 10.7803L8 9.06066L9.71967 10.7803C10.0126 11.0732 10.4874 11.0732 10.7803 10.7803C11.0732 10.4874 11.0732 10.0126 10.7803 9.71967L9.06066 8L10.7803 6.28033C11.0732 5.98744 11.0732 5.51256 10.7803 5.21967C10.4874 4.92678 10.0126 4.92678 9.71967 5.21967L8 6.93934L6.28033 5.21967Z" /></svg>`,
    error: `<svg viewBox="0 0 16.0626 14.375" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.51575 0.875C7.18933 -0.291669 8.87326 -0.291665 9.54684 0.875L15.8255 11.75C16.4991 12.9167 15.6571 14.375 14.31 14.375H1.75261C0.405458 14.375 -0.436508 12.9167 0.237066 11.75L6.51575 0.875ZM8.03125 3.38C8.44546 3.38 8.78125 3.71579 8.78125 4.13V7.63C8.78125 8.04422 8.44546 8.38 8.03125 8.38C7.61704 8.38 7.28125 8.04422 7.28125 7.63L7.28125 4.13C7.28125 3.71579 7.61704 3.38 8.03125 3.38ZM8.03125 12.38C8.58353 12.38 9.03125 11.9323 9.03125 11.38C9.03125 10.8277 8.58353 10.38 8.03125 10.38C7.47897 10.38 7.03125 10.8277 7.03125 11.38C7.03125 11.9323 7.47897 12.38 8.03125 12.38Z" /></svg>`,
    success: `<svg viewBox="0 0 16.25 16.25" fill="currentColor"><path fill-rule="evenodd" clip-rule="evenodd" d="M0 8.125C0 3.63769 3.63769 0 8.125 0C12.6123 0 16.25 3.63769 16.25 8.125C16.25 12.6123 12.6123 16.25 8.125 16.25C3.63769 16.25 0 12.6123 0 8.125ZM11.1336 6.61327C11.3342 6.33239 11.2692 5.94205 10.9883 5.74142C10.7074 5.54079 10.317 5.60584 10.1164 5.88673L7.42025 9.66136L6.06694 8.30806C5.82286 8.06398 5.42714 8.06398 5.18306 8.30806C4.93898 8.55214 4.93898 8.94786 5.18306 9.19194L7.05806 11.0669C7.18797 11.1969 7.36846 11.263 7.55155 11.2479C7.73464 11.2327 7.9018 11.1378 8.00858 10.9883L11.1336 6.61327Z" /></svg>`,
  };

  // ── Size ─────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-prop="size"]').forEach(btn => {
    btn.addEventListener('click', () => {
      activate(btn);
      preview.classList.remove('field--large', 'field--medium');
      preview.classList.add(`field--${btn.dataset.value}`);
    });
  });

  // ── Status ───────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-prop="status"]').forEach(btn => {
    btn.addEventListener('click', () => {
      activate(btn);
      preview.classList.remove('field--hover', 'field--focus', 'field--disabled');
      const value = btn.dataset.value!;
      if (input) input.disabled = value === 'disabled';
      if (value !== 'default') preview.classList.add(`field--${value}`);
    });
  });

  // ── Result ───────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-prop="result"]').forEach(btn => {
    btn.addEventListener('click', () => {
      activate(btn);
      preview.classList.remove('field--error', 'field--success');
      const value = btn.dataset.value!;
      if (value !== 'none') preview.classList.add(`field--${value}`);
      if (iconRight) iconRight.innerHTML = ICON_RIGHT[value];
    });
  });

  // ── Icon left / right ────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-prop="iconLeft"]').forEach(btn => {
    btn.addEventListener('click', () => {
      activate(btn);
      if (iconLeft) iconLeft.style.display = btn.dataset.value === 'true' ? 'flex' : 'none';
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-prop="iconRight"]').forEach(btn => {
    btn.addEventListener('click', () => {
      activate(btn);
      if (iconRight) iconRight.style.display = btn.dataset.value === 'true' ? 'flex' : 'none';
    });
  });

  // ── Placeholder text ─────────────────────────────────────────
  const placeholderInput = document.querySelector<HTMLInputElement>('#ctrl-placeholder');
  placeholderInput?.addEventListener('input', () => {
    if (input) input.placeholder = placeholderInput.value;
  });
</script>


<style>
  /* ══════════════════════════════════════════════════════════════
     FIELD COMPONENT STYLES
     The playground's manually written .field markup mirrors
     Field.astro's own scoped styles.
  ══════════════════════════════════════════════════════════════ */

  .field {
    position: relative;
    display: flex;
    align-items: center;
    box-sizing: border-box;
    width: 100%;
    gap: var(--spacing-8);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-xlg);
    background: var(--surface-default-dark);
    box-shadow: inset 0px 4px 4px var(--black-60);
    transition: border-color 0.15s, background-color 0.15s;
  }

  .field--large { height: 56px; padding: var(--spacing-16) var(--spacing-12); }
  .field--medium { height: 48px; padding: var(--spacing-8) var(--spacing-12); }

  .field__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--icon-default);
  }

  .field__icon svg { display: block; width: 100%; height: 100%; }

  .field__input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font-family-body);
    font-size: var(--font-size-paragraph-md);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-paragraph-md);
    color: var(--text-action-light);
  }

  .field__input::placeholder { color: var(--text-placeholder); }

  .field:hover:not(.field--disabled),
  .field--hover,
  .field:focus-within:not(.field--disabled),
  .field--focus {
    border-color: var(--border-hover);
    background: var(--surface-hover-dark);
  }

  .field:hover:not(.field--disabled) .field__input::placeholder,
  .field--hover .field__input::placeholder,
  .field:focus-within:not(.field--disabled) .field__input::placeholder,
  .field--focus .field__input::placeholder {
    color: var(--text-placeholder-focus);
  }

  .field--disabled {
    border-color: var(--border-disabled);
    background: var(--surface-disabled-dark);
  }

  .field--disabled .field__input {
    color: var(--text-action-light-disabled);
    cursor: not-allowed;
  }

  .field--disabled .field__input::placeholder { color: var(--text-action-light-disabled); }
  .field--disabled .field__icon { color: var(--icon-action-light-disabled); }

  .field--error {
    border-color: var(--border-error);
    background: var(--surface-error);
  }

  .field--error .field__input,
  .field--error .field__input::placeholder {
    color: var(--text-error-light);
  }

  .field--error .field__icon { color: var(--icon-error); }

  .field--success { border-color: var(--border-success); }
  .field--success .field__icon { color: var(--icon-success); }


  /* ══════════════════════════════════════════════════════════════
     PLAYGROUND
  ══════════════════════════════════════════════════════════════ */

  .playground {
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 48px;
  }

  .playground__stage {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    padding: 40px 32px;
    background: var(--surface-page);
  }

  .preview-wrap { width: 360px; }

  .playground__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ctrl-group { border: none; padding: 0; }

  .ctrl-group__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-placeholder);
    margin-bottom: 8px;
  }

  .ctrl-group__options { display: flex; gap: 6px; flex-wrap: wrap; }

  .ctrl-btn {
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: var(--text-body-default);
    font-family: var(--font-family-body);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .ctrl-btn:hover     { background: var(--surface-hover-dark); }
  .ctrl-btn.is-active {
    background:   var(--primary-900);
    color:        var(--primary-300);
    border-color: var(--primary-700);
  }

  .ctrl-input {
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    color: var(--text-body-default);
    font-family: var(--font-family-body);
    font-size: 0.8rem;
    padding: 5px 10px;
    outline: none;
    width: 220px;
    transition: border-color 0.15s;
  }

  .ctrl-input:focus { border-color: var(--primary-600); }


  /* ══════════════════════════════════════════════════════════════
     VARIANT EXAMPLES
  ══════════════════════════════════════════════════════════════ */

  .example-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 24px;
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    margin: 12px 0 32px;
  }

  .example-row--col { flex-direction: column; align-items: stretch; gap: 12px; }

  .size-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    align-items: center;
    gap: 16px;
    max-width: 480px;
  }

  .size-label {
    font-size: var(--font-size-paragraph-sm);
    color: var(--text-placeholder);
    white-space: nowrap;
  }

  .form-stack {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-8);
    max-width: 360px;
  }


  /* ══════════════════════════════════════════════════════════════
     DO'S & DON'TS
  ══════════════════════════════════════════════════════════════ */

  .dos-donts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 0 24px;
  }

  .dos-donts__col {
    padding: 16px 20px;
    border-radius: 10px;
  }

  .dos-donts__col--do {
    background: color-mix(in srgb, var(--success-default) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--success-default) 30%, transparent);
  }

  .dos-donts__col--dont {
    background: color-mix(in srgb, var(--error-default) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--error-default) 30%, transparent);
  }

  .dos-donts__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .dos-donts__col--do   .dos-donts__label { color: var(--success-default); }
