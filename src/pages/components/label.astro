---
import DocLayout from '../../layouts/DocLayout.astro';
import Label from '../../components/Label/Label.astro';

const headings = [
  { depth: 2, slug: 'variants',  text: 'Variants' },
  { depth: 3, slug: 'type',      text: 'Type' },
  { depth: 3, slug: 'hint',      text: 'Hint' },
  { depth: 2, slug: 'usage',     text: 'Usage' },
  { depth: 2, slug: 'dos-donts', text: "Do's & Don'ts" },
];
---

<DocLayout
  title="Label"
  description="Sits above every input field to tell the student what to fill in. Turns red-asterisk when the field is required."
  headings={headings}
>

  <!-- ═══════════════════════════════════════════════
       PLAYGROUND
       All optional elements pre-rendered; JS toggles
       CSS classes only — no DOM manipulation needed.
  ════════════════════════════════════════════════ -->
  <section class="playground" aria-label="Interactive preview">

    <div class="playground__stage">
      <!--
        .label__asterisk and .label__hint-btn are always in the DOM.
        CSS hides them by default; .is-required / .has-hint reveals them.
      -->
      <label class="label" id="preview-label">
        <span class="label__asterisk" aria-hidden="true">*</span>
        <span class="label__text">Nombre completo</span>
        <button class="label__hint-btn" type="button" title="" aria-label="">
          <svg class="label__hint-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/>
          </svg>
        </button>
      </label>
    </div>

    <div class="playground__controls" role="group" aria-label="Playground controls">

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Type</legend>
        <div class="ctrl-group__options">
          {['default', 'required'].map(t => (
            <button
              class:list={['ctrl-btn', { 'is-active': t === 'default' }]}
              data-prop="type"
              data-value={t}
            >{t}</button>
          ))}
        </div>
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Label text</legend>
        <input class="ctrl-input" type="text" id="ctrl-label-text" value="Nombre completo" maxlength="40" />
      </fieldset>

      <fieldset class="ctrl-group">
        <legend class="ctrl-group__label">Hint</legend>
        <input class="ctrl-input" type="text" id="ctrl-hint" placeholder="Add hint text…" maxlength="80" />
      </fieldset>

    </div>

  </section>


  <!-- ═══════════════════════════════════════════════
       VARIANTS
  ════════════════════════════════════════════════ -->
  <h2 id="variants">Variants</h2>

  <h3 id="type">Type</h3>
  <p>Two types: <code>default</code> for optional fields, <code>required</code> for fields the student can't skip. The red asterisk draws the eye without cluttering the field.</p>

  <div class="example-row">
    <div class="variant-item">
      <span class="variant-caption">Default</span>
      <Label label="Nombre completo" />
    </div>
    <div class="variant-item">
      <span class="variant-caption">Required</span>
      <Label label="Correo electrónico" required={true} />
    </div>
  </div>

  <h3 id="hint">Hint</h3>
  <p>Pass a <code>hint</code> string to add the question-mark icon. Use it when the field name alone doesn't explain what's expected — keep the hint short and specific.</p>

  <div class="example-row">
    <div class="variant-item">
      <span class="variant-caption">With hint</span>
      <Label label="Código de acceso" hint="El código de 6 dígitos que recibiste por email" />
    </div>
    <div class="variant-item">
      <span class="variant-caption">Required + hint</span>
      <Label label="Fecha de nacimiento" required={true} hint="Formato DD / MM / AAAA" />
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════
       USAGE
  ════════════════════════════════════════════════ -->
  <h2 id="usage">Usage</h2>
  <p>Put a Label above every input, select, or textarea in a form. Always pass the <code>for</code> prop with the input's <code>id</code> so tapping the label focuses the field. On small screens where input tap targets are tight, this makes a real difference.</p>
  <p>Be consistent with <code>required</code>: if you mark some fields, mark all mandatory ones. Students learn the pattern fast — one unmarked required field breaks their trust.</p>


  <!-- ═══════════════════════════════════════════════
       DO'S & DON'TS
  ════════════════════════════════════════════════ -->
  <h2 id="dos-donts">Do's & Don'ts</h2>

  <div class="dos-donts">
    <div class="dos-donts__col dos-donts__col--do">
      <p class="dos-donts__label">Do</p>
      <ul>
        <li><strong>Always link label to input.</strong> Pass <code>for="input-id"</code>. Skip this and the label is just decoration — it won't focus the field on tap.</li>
        <li><strong>Mark every mandatory field.</strong> Use <code>required</code> on all fields the student can't leave blank. Don't make them discover it at submission.</li>
        <li><strong>Keep it short.</strong> One or two words. "Correo electrónico", "Contraseña", "Fecha de nacimiento". Move longer explanations into <code>hint</code>.</li>
      </ul>
    </div>
    <div class="dos-donts__col dos-donts__col--dont">
      <p class="dos-donts__label">Don't</p>
      <ul>
        <li><strong>Don't use it outside a form.</strong> It's a form element. For headings or captions elsewhere, use a regular text style instead.</li>
        <li><strong>Don't write full sentences as the label.</strong> "Please enter your full legal name" belongs in <code>hint</code>, not the label itself.</li>
        <li><strong>Don't mix required conventions.</strong> If you use asterisks on some required fields but not others, students won't know what to trust.</li>
      </ul>
    </div>
  </div>

  <hr />

  <p>
    <strong>Related:</strong>
    <a href="/components/option-card">Option Card</a> (label-like text inside answer choices)
  </p>

</DocLayout>


<script>
  const preview = document.querySelector<HTMLElement>('#preview-label');
  if (!preview) throw new Error('#preview-label not found');

  // ── Type control ─────────────────────────────────────────────
  // Toggles .is-required on the label element.
  // CSS handles asterisk visibility — no DOM manipulation needed.
  document.querySelectorAll<HTMLButtonElement>('[data-prop="type"]').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.ctrl-group__options')!
        .querySelectorAll('.ctrl-btn')
        .forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      preview.classList.toggle('is-required', btn.dataset.value === 'required');
    });
  });

  // ── Label text ───────────────────────────────────────────────
  const labelInput = document.querySelector<HTMLInputElement>('#ctrl-label-text');
  labelInput?.addEventListener('input', () => {
    const el = preview.querySelector('.label__text');
    if (el) el.textContent = labelInput.value;
  });

  // ── Hint ─────────────────────────────────────────────────────
  // Toggles .has-hint; also updates the tooltip text on the button.
  const hintInput = document.querySelector<HTMLInputElement>('#ctrl-hint');
  const hintBtn   = preview.querySelector<HTMLButtonElement>('.label__hint-btn');

  hintInput?.addEventListener('input', () => {
    const text = hintInput.value.trim();
    preview.classList.toggle('has-hint', text.length > 0);
    if (hintBtn) {
      hintBtn.title = text;
      hintBtn.setAttribute('aria-label', text ? `Más info: ${text}` : '');
    }
  });
</script>


<style>
  /* ══════════════════════════════════════════════════════════════
     LABEL COMPONENT STYLES
     These apply to:
       - The playground's manually written <label class="label"> (page scope)
       - JS class toggles on that element
     The <Label /> instances in the Variants section get their styles
     from Label.astro's own scoped block.
  ══════════════════════════════════════════════════════════════ */

  .label {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-4);
    cursor: default;
  }

  .label__text {
    font-family: var(--font-family-body);
    font-size: var(--font-size-paragraph-md);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-paragraph-md);
    color: var(--text-body-default);
  }

  .label__asterisk {
    font-family: var(--font-family-body);
    font-size: var(--font-size-paragraph-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-paragraph-md);
    color: var(--icon-error);
    user-select: none;
    /* Hidden by default in the playground; .is-required reveals it */
    display: none;
  }

  .is-required .label__asterisk {
    display: inline;
  }

  .label__hint-btn {
    display: none; /* Hidden by default; .has-hint reveals it */
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--text-placeholder);
    line-height: 0;
    border-radius: var(--radius-xsm);
    transition: color 0.15s;
  }

  .has-hint .label__hint-btn {
    display: inline-flex;
  }

  .label__hint-btn:hover { color: var(--text-body-default); }

  .label__hint-btn:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 2px;
  }

  .label__hint-icon {
    display: block;
    flex-shrink: 0;
  }


  /* ══════════════════════════════════════════════════════════════
     PLAYGROUND
  ══════════════════════════════════════════════════════════════ */

  .playground {
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 48px;
  }

  .playground__stage {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    padding: 40px 32px;
    background: var(--surface-page);
  }

  .playground__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ctrl-group { border: none; padding: 0; }

  .ctrl-group__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-placeholder);
    margin-bottom: 8px;
  }

  .ctrl-group__options { display: flex; gap: 6px; flex-wrap: wrap; }

  .ctrl-btn {
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: var(--text-body-default);
    font-family: var(--font-family-body);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .ctrl-btn:hover     { background: var(--surface-hover-dark); }
  .ctrl-btn.is-active {
    background:   var(--primary-900);
    color:        var(--primary-300);
    border-color: var(--primary-700);
  }

  .ctrl-input {
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    color: var(--text-body-default);
    font-family: var(--font-family-body);
    font-size: 0.8rem;
    padding: 5px 10px;
    outline: none;
    width: 220px;
    transition: border-color 0.15s;
  }

  .ctrl-input:focus { border-color: var(--primary-600); }


  /* ══════════════════════════════════════════════════════════════
     VARIANT EXAMPLES
  ══════════════════════════════════════════════════════════════ */

  .example-row {
    display: flex;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
    padding: 28px 24px;
    background: var(--surface-elevate);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    margin: 12px 0 32px;
  }

  .variant-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-8);
  }

  .variant-caption {
    font-size: var(--font-size-paragraph-xsm);
    color: var(--text-placeholder);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }


  /* ══════════════════════════════════════════════════════════════
     DO'S & DON'TS
  ══════════════════════════════════════════════════════════════ */

  .dos-donts {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 16px 0 24px;
  }

  .dos-donts__col {
    padding: 16px 20px;
    border-radius: 10px;
  }

  .dos-donts__col--do {
    background: color-mix(in srgb, var(--success-default) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--success-default) 30%, transparent);
  }

  .dos-donts__col--dont {
    background: color-mix(in srgb, var(--error-default) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--error-default) 30%, transparent);
  }

  .dos-donts__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .dos-donts__col--do   .dos-donts__label { color: var(--success-default); }
  .dos-donts__col--dont .dos-donts__label { color: var(--error-default); }

  .dos-donts__col ul {
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dos-donts__col li {
    font-size: var(--font-size-paragraph-sm);
    line-height: var(--line-height-paragraph-sm);
    color: var(--text-body-default);
  }
</style>
